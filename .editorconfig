# EditorConfig 统一编辑器配置
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100

[*.md]
trim_trailing_whitespace = false

[*.py]
indent_size = 4
max_line_length = 100

[*.{tmpl,html}]
indent_size = 2

[*.{css,js}]
indent_size = 2
